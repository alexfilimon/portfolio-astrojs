---
interface Props {
  name: string;
  subtitle: string;
  avatarSrc: string;
}

const { name, subtitle, avatarSrc } = Astro.props;
---

<div class="flex flex-col items-center text-center profile-enter">
  <img
    src={avatarSrc}
    alt={name}
    width="128"
    height="128"
    class="w-28 h-28 sm:w-32 sm:h-32 rounded-full object-cover ring-2 ring-border ring-offset-2 ring-offset-background"
    loading="eager"
  />
  <h1 class="mt-4 text-2xl sm:text-3xl font-bold text-foreground">
    {name}
  </h1>
  <p class="mt-1 text-base text-muted-foreground">
    {subtitle}
  </p>
</div>
