---
import type { Locale } from '@/i18n/ui';
import { t, getAlternateLocale, getLocalizedPath } from '@/i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const altLocale = getAlternateLocale(locale);
const switchLabel = t(locale, 'language.switch.label');
const href = getLocalizedPath(altLocale);

const flags: Record<string, string> = {
  en: '🇬🇧',
  ru: '🇷🇺',
};
const flag = flags[altLocale] ?? '';
---

<a
  href={href}
  class="flex items-center gap-1.5 px-2.5 py-1.5 text-sm font-medium rounded-md text-muted-foreground hover:text-foreground hover:bg-accent transition-colors"
>
  <span class="text-base leading-none">{flag}</span>
  <span>{switchLabel}</span>
  
</a>
